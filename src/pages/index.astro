---
import Layout from "../layouts/Base.astro";

function duration(start: Date, end?: Date): string {
  const to = end ?? new Date();
  const months =
    (to.getFullYear() - start.getFullYear()) * 12 +
    (to.getMonth() - start.getMonth());
  const yrs = Math.floor(months / 12);
  const mos = months % 12;
  const parts = [];
  if (yrs > 0) parts.push(`${yrs} р.`);
  if (mos > 0) parts.push(`${mos} міс.`);
  return parts.join(" ");
}

function formatDate(d: Date): string {
  return d.toLocaleDateString("uk-UA", { month: "short", year: "numeric" });
}

